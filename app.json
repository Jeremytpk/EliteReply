{
  "expo": {
    "name": "EliteReply",
    "slug": "EliteReply",
    "version": "1.0.0", // REMINDER: INCREMENT THIS FOR EACH NEW BUILD
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "elitereply",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set a profile picture.",
          "cameraPermission": "The app accesses your camera to let you take a profile picture."
        }
      ],
      [
        "expo-notifications", // This is the correct way to configure expo-notifications plugin
        {
          "icon": "./assets/images/notification-icon.png", // Android specific (optional, falls back to main app icon)
          "color": "#0a8fdf", // Android specific accent color for notifications
          "androidMode": "default",
          "androidCollapsedTitle": "#{unread_notifications} nouveaux messages",
          "sounds": [
            // Android: This array directly under the plugin handles sounds for Android
            "./assets/sounds/er_notification.mp3"
          ],
          "android": {
            // Any additional Android specific notification configurations for the plugin go here.
          },
          "ios": {
            "allowForeground": true, // Allows notifications to show when app is in foreground
            "supportsTablet": true,
            "sounds": [
              {
                "name": "er_notification", // This is the name used in your Cloud Function payload
                "path": "./assets/sounds/er_notification.wav", // Path to your .wav file for iOS
                "type": "wav" // Type must be 'wav' for .wav files
              }
            ]
          }
        }
      ]
      // Any other plugins you have
    ],
    "splash": {
      "image": "./assets/images/logoVide.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your app needs access to your location to provide personalized services.",
        "NSMicrophoneUsageDescription": "EliteReply needs access to your microphone for voice commands and speech recognition."
      },
      "bundleIdentifier": "com.yourcompany.elitereply",
      "buildNumber": "1.0.0" // REMINDER: INCREMENT THIS FOR EACH NEW iOS BUILD
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptiveIcon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourcompany.elitereply",
      "versionCode": 1, // REMINDER: INCREMENT THIS FOR EACH NEW ANDROID BUILD
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "elitereply",
              "host": "app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "extra": {
      "eas": {
        "projectId": "2ed09575-61d8-47b8-ae78-ee5bfbf930f9"
      }
    },
    "doctor": { // <--- ADDED: Configuration for expo-doctor checks
      "reactNativeDirectoryCheck": {
        "exclude": [
          "firebase",
          "moment",
          "moment-timezone",
          "openai",
          "react-native-chart-kit",       
          "react-native-element-dropdown", 
          "react-native-swiper"            
        ],
        "listUnknownPackages": false // Optional: set to true if you want warnings for *all* unknown packages
      }
    }
  }
}